WiFiClientSecure client;
client.setInsecure();

HTTPClient https;

String url = String(firebaseHost) + "/live.json";

String json = "{";

json += "\"temperature\":" + String(temperatureC) + ",";
json += "\"ph\":" + String(phValue) + ",";
json += "\"ec\":" + String(ecValue) + ",";
